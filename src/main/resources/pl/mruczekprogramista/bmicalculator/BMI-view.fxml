<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="pl.mruczekprogramista.bmicalculator.BMIController">
  <padding>
    <Insets bottom="20.0" left="100.0" right="100.0" top="100.0"/>
  </padding>


    <Label text="Podaj swój wzrost w cm"/>
    <TextField fx:id="height"/>
    <Label text="Podaj swoją wagę w kg"/>
    <TextField fx:id="wage" onAction="#calculateBmi"/>
    <Button text="Oblicz" onAction="#calculateBmi" />
    <Label text="Twoje BMI wynosi: "/>
    <Label fx:id="result" />
    <Label fx:id="bmiValue"/>
    <Button text="Wyczyść" onAction="#clearFields"/>


</VBox>
